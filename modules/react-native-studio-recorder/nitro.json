{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["studiorecorder"],
  "ios": {
    "iosModuleName": "NitroStudiorecorder"
  },
  "android": {
    "androidNamespace": ["studiorecorder"],
    "androidCxxLibName": "NitroStudiorecorder"
  },
  "autolinking": {
    "NitroStudioRecorder": {
      "ios": {
        "language": "swift",
        "implementationClassName": "StudioRecorderHybridObject"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "StudioRecorderHybridObject"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
