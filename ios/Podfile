require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
# Resolve react_native_pods.rb through Node so hoisted installs still work.
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '16.0'
prepare_react_native_project!

target 'LilliesApp' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(require.resolve(\'expo-modules-autolinking\', { paths: [require.resolve(\'expo/package.json\')] }))(process.argv.slice(1))',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  # react-native-studio-recorder is auto-discovered by use_native_modules! once
  # the package is installed (same mechanism as native-flow / date-picker).
  # If pod install reports StudioRecorder not found, uncomment the line below:
  # pod 'StudioRecorder', :path => '../studio-recorder'

  use_react_native!(
    :path => config[:reactNativePath],
    :new_arch_enabled => true,
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # Sign the hermesvm.framework so it can be installed on physical devices.
  # The pre-built binary shipped with RN 0.83 is unsigned.
  script_phase :name => 'Sign Hermes Framework',
               :script => '"${PODS_ROOT}/../sign_hermes.sh"',
               :execution_position => :after_compile

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )
  end
end
